[rke2_servers]
%{ for host in servers ~}
${host.name} ansible_host=${host.public_ip} public_ip=${host.public_ip} private_ip=${host.private_ip} ansible_user=ec2-user
%{ endfor ~}

[rke2_agents]
%{ for host in agents ~}
${host.name} ansible_host=${host.public_ip} public_ip=${host.public_ip} private_ip=${host.private_ip} ansible_user=ec2-user
%{ endfor ~}

[all:vars]
ansible_user=ec2-user
ansible_ssh_private_key_file=/home/rlrandall/work-stuff/irad/rke2-aws-deployment/rke2-key.pem